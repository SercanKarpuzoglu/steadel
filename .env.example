# --- Core ---------------------------------------------------------------
# Public URL of the app (no trailing slash)
APP_URL=http://localhost:3000
NODE_ENV=development

# Postgres connection string
DATABASE_URL=postgres://steadel:steadel@localhost:55432/steadel

# Redis connection string (BullMQ queues)
REDIS_URL=redis://localhost:56379

# 32-byte hex key for AES-256-GCM encryption of third-party credentials.
# Generate with: openssl rand -hex 32
APP_ENCRYPTION_KEY=

# Secret for Auth.js session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Comma-separated list of emails allowed into /admin
ADMIN_EMAILS=

# --- Email (SMTP, EU-region provider) ------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Steadel <no-reply@steadel.com>"
# In development, when SMTP_HOST is empty, emails are logged to stdout.

# --- Shopify -------------------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# --- Meta Ads (behind feature flag) --------------------------------------
ADS_GUARD_ENABLED=false
META_APP_ID=
META_APP_SECRET=

# --- Paddle Billing -------------------------------------------------------
# When BILLING_ENABLED=false the app runs in dev mode without Paddle.
BILLING_ENABLED=false
PADDLE_ENV=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_CLIENT_TOKEN=
PADDLE_PRICE_STARTER=
PADDLE_PRICE_GROWTH=
PADDLE_PRICE_AGENCY=

# --- Development helpers ---------------------------------------------------
# 1 = offer "connect demo store / demo ad account" buttons (mock providers).
# Also implied when SHOPIFY_API_KEY is empty.
MOCK_STORE_PROVIDER=

# --- Logging --------------------------------------------------------------
# Directory for rotated log files; empty = pretty stdout logs (dev)
LOG_DIR=
LOG_LEVEL=info
